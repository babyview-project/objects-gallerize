# Copy this file to .env and fill in your values

# --- Data source ---
# "mongodb" (default) or "local_csv"
DATA_SOURCE=mongodb

# --- MongoDB (used when DATA_SOURCE=mongodb) ---
# Include the database name in the URL: .../bv-objects?authSource=admin
MONGO_URL=mongodb://USERNAME:PASSWORD@vislearnlab.ucsd.edu:27017/bv-objects?authSource=admin

# --- CSV mode (used when DATA_SOURCE=local_csv) ---
# Path to the CSV file with columns: filename,session_id,age,class,url,shuffler_ind
DATA_CSV_PATH=./data/annotations.csv
# Directory containing the image files (served at /img/)
IMG_DIR=./img
# URL prefix prepended to image paths (e.g. /gallerize when behind a reverse proxy subpath)
IMG_URL_PREFIX=

